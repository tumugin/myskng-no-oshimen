{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": false
  },
  "packageRules": [
    {
      "matchPackageNames": ["next"],
      "groupName": "Next.js"
    },
    {
      "matchPackageNames": ["@next/*"],
      "groupName": "Next.js"
    },
    {
      "groupName": "non-major dependencies",
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackageNames": ["!next", "!@next/*"]
    }
  ]
}
